              "type": "boolean"
            },
            ".left.comment": {
              "type": "string"
            },
            ".right.comment": {
              "type": "string"
            }
          },
          "unevaluatedProperties": false
        }
      }
    },
    "goid": {
      "type": "string",
      "$id": "schema:sub-types/goid"
