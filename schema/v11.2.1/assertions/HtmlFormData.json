        },
        "dataType": {
          "$ref": "https://l7tech.com/2025/json-schema/assertions/sub-types/htmlFormDataType"
        },
        "maxOccurs": {
          "type": "integer",
          "default": 0
        },
        "minOccurs": {
          "type": "integer",
          "default": 0
        },
        "name": {
          "type": "string"
        }
      }
    },
    {
