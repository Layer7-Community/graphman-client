        "anywhere",
        "requestUrl",
        "requestBody"
      ]
    },
    {
      "type": "string",
      "$id": "https://l7tech.com/2025/json-schema/assertions/sub-types/htmlFormDataType",
      "enum": [
        "any",
        "number",
        "file",
        "string"
      ]
    },
    {
      "type": "object",
      "$id": "https://l7tech.com/2025/json-schema/assertions/HtmlFormData/Main",
      "title": "Validate HTML Form Data",
      "properties": {
        "HtmlFormData": {
          "$ref": "https://l7tech.com/2025/json-schema/assertions/HtmlFormData"
        }
      }
    }
