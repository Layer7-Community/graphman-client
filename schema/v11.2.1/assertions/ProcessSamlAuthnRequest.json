        },
        "requiredProtocolBinding": {
          "type": "boolean",
          "default": false
        },
        "requiredProviderName": {
          "type": "boolean",
          "default": false
        },
        "samlProtocolBinding": {
          "type": "string",
          "enum": [
            "HttpPost",
            "HttpRedirect"
          ]
        },
        "target": {
          "type": "string",
          "enum": [
            "REQUEST",
            "RESPONSE",
            "OTHER"
          ],
          "default": "REQUEST"
        },
        "variablePrefix": {
          "type": "string",
          "default": "authnRequest"
        },
        "verifySignature": {
          "type": "boolean",
          "default": true
        },
        "_enabled": {
          "type": "boolean",
          "default": true
        },
        "_leftComment": {
          "type": "string"
        },
        "_rightComment": {
          "type": "string"
        }
      }
    },
    {
      "type": "object",
      "$id": "https://l7tech.com/2025/json-schema/assertions/ProcessSamlAuthnRequest/Main",
