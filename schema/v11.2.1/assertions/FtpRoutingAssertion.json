{
  "$comment": "Schema for FtpRoutingAssertion assertion. Self-contained with all dependencies.",
  "definitions": {
    "assertion": {
      "$id": "schema:assertion",
      "type": "object",
      "properties": {
        ".properties": {
          "type": "object",
          "properties": {
            ".enabled": {
              "type": "boolean"
            },
            ".left.comment": {
              "type": "string"
            },
            ".right.comment": {
              "type": "string"
            }
          },
          "unevaluatedProperties": false
        }
      }
    },
    "goid": {
      "type": "string",
      "$id": "schema:sub-types/goid"
    },
    "FtpRoutingAssertion:credentialsSource": {
      "type": "string",
      "$id": "schema:FtpRoutingAssertion:credentialsSource"
    },
    "xmlSecurityRecipientContext": {
      "type": "object",
      "$id": "schema:sub-types/xmlSecurityRecipientContext",
      "properties": {
        "actor": {
          "type": "string"
        },
        "base64edX509Certificate": {
          "type": "string"
        }
      },
      "unevaluatedProperties": false
    },
    "messageTargetableSupport": {
      "type": "object",
      "$id": "schema:sub-types/messageTargetableSupport",
      "properties": {
        "otherTargetMessageVariable": {
          "type": "string"
        },
        "sourceUsedByGateway": {
          "type": "boolean",
          "default": true
        },
        "target": {
          "type": "string",
          "enum": [
            "REQUEST",
            "RESPONSE",
            "OTHER"
          ],
          "default": "RESPONSE"
        },
        "targetModifiedByGateway": {
          "type": "boolean",
          "default": false
        }
      },
      "unevaluatedProperties": false
    },
    "FtpRoutingAssertion:security": {
      "type": "string",
      "$id": "schema:FtpRoutingAssertion:security"
    },
    "ftpRoutingAssertion": {
      "type": "object",
      "$id": "schema:FtpRoutingAssertion",
      "$ref": "schema:assertion",
      "properties": {
        "FtpRoutingAssertion": {
          "type": "object",
          "properties": {
            "arguments": {
              "type": "string"
            },
            "clientCertKeyAlias": {
              "type": "string"
            },
            "clientCertKeystoreId": {
              "$ref": "schema:sub-types/goid"
            },
            "commandFromVariable": {
              "type": "boolean",
              "default": false
            },
            "credentialsSource": {
              "$ref": "schema:FtpRoutingAssertion:credentialsSource",
              "enum": [
                "passThru",
                "specified"
              ],
              "default": "passThru"
            },
            "currentSecurityHeaderHandling": {
              "type": "integer",
              "default": 1
            },
            "directory": {
              "type": "string"
            },
            "failureMode": {
              "type": "string",
              "enum": [
                "0",
                "1",
                "2"
              ],
              "default": "0"
            },
            "ftpCommand": {
              "type": "string"
            },
            "ftpCommandVariable": {
              "type": "string"
            },
            "hostName": {
              "type": "string"
            },
            "password": {
              "type": "string"
            },
            "passwordGoid": {
              "type": "string"
            },
            "passwordUsesContextVariables": {
              "type": "boolean",
              "default": false
            },
            "port": {
              "type": "string"
            },
            "recipientContext": {
              "$ref": "schema:sub-types/xmlSecurityRecipientContext"
            },
            "requestTarget": {
              "$ref": "schema:sub-types/messageTargetableSupport"
            },
            "responseByteLimit": {
              "type": "string"
            },
            "responseTarget": {
              "$ref": "schema:sub-types/messageTargetableSupport"
            },
            "security": {
              "$ref": "schema:FtpRoutingAssertion:security"
            },
            "timeout": {
              "type": "integer"
            },
            "useClientCert": {
              "type": "boolean",
              "default": false
            },
            "userName": {
              "type": "string"
            },
            "verifyServerCert": {
              "type": "boolean",
              "default": false
            },
            "xmlSecurityActorToPromote": {
              "type": "string"
            }
          },
          "unevaluatedProperties": false
        }
      },
      "unevaluatedProperties": false
    }
  },
  "type": "object",
  "$ref": "schema:FtpRoutingAssertion"
}
