{
  "$comment": "Schema for ComparisonAssertion assertion. Self-contained with all dependencies.",
  "definitions": {
    "assertion": {
      "$id": "schema:assertion",
      "type": "object",
      "properties": {
        ".properties": {
          "type": "object",
          "properties": {
            ".enabled": {
              "type": "boolean"
            },
            ".left.comment": {
              "type": "string"
            },
            ".right.comment": {
              "type": "string"
            }
          },
          "unevaluatedProperties": false
        }
      }
    },
    "comparisonAssertion": {
      "type": "object",
      "$id": "schema:ComparisonAssertion",
      "$ref": "schema:assertion",
      "properties": {
        "ComparisonAssertion": {
          "type": "object",
          "properties": {
            "expression1": {
              "type": "string"
            },
            "expressionIsVariable": {
              "type": "boolean"
            },
            "multivaluedComparison": {
              "type": "string",
              "enum": [
                "ANY",
                "ALL",
                "FIRST",
                "LAST",
                "FAIL"
              ]
            },
            "negate": {
              "type": "boolean"
            },
            "predicates": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "negated": {
                    "type": "boolean"
                  }
                }
              }
            }
          },
          "unevaluatedProperties": false
        }
      },
      "unevaluatedProperties": false
    }
  },
  "type": "object",
  "$ref": "schema:ComparisonAssertion"
}
