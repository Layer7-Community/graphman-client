        "userLogin": {
          "type": "string"
        },
        "userName": {
          "type": "string"
        },
        "userUid": {
          "type": "string"
        },
        "_enabled": {
          "type": "boolean",
          "default": true
        },
        "_leftComment": {
          "type": "string"
        },
        "_rightComment": {
          "type": "string"
        }
