    },
    {
      "type": "string",
      "$id": "https://l7tech.com/2025/json-schema/assertions/sub-types/goid"
    },
    {
      "type": "object",
      "$id": "https://l7tech.com/2025/json-schema/assertions/SpecificUser/Main",
      "title": "Authenticate User or Group",
      "properties": {
        "SpecificUser": {
          "$ref": "https://l7tech.com/2025/json-schema/assertions/SpecificUser"
        }
