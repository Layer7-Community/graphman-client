{
  "configName": "CORS",
  "name": "Process CORS Request",
  "configSchemas": [
    {
      "$id": "https://l7tech.com/2025/json-schema/assertions/CORS",
      "title": "Process CORS Request",
      "type": "object",
      "properties": {
        "acceptSameOriginRequests": {
          "type": "boolean",
          "default": false
        },
        "acceptedHeaders": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "acceptedMethods": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "acceptedOrigins": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "allowNonStandardMethods": {
          "type": "boolean",
          "default": false
        },
        "dynamicOrigins": {
          "type": "string"
        },
        "exposedHeaders": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "requireCors": {
          "type": "boolean",
          "default": true
        },
        "responseCacheTime": {
          "type": "string"
