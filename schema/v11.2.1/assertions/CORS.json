        "supportsCredentials": {
          "type": "boolean",
          "default": true
        },
        "variablePrefix": {
          "type": "string",
          "default": "cors"
        },
        "_enabled": {
          "type": "boolean",
          "default": true
        },
        "_leftComment": {
          "type": "string"
        },
        "_rightComment": {
          "type": "string"
        }
      }
    },
    {
      "type": "object",
      "$id": "https://l7tech.com/2025/json-schema/assertions/CORS/Main",
      "title": "Process CORS Request",
      "properties": {
        "CORS": {
          "$ref": "https://l7tech.com/2025/json-schema/assertions/CORS"
        }
      }
    }
  ]
