{
  "$comment": "Schema for HttpDigest assertion. Self-contained with all dependencies.",
  "definitions": {
    "assertion": {
      "$id": "schema:assertion",
      "type": "object",
      "properties": {
        ".properties": {
          "type": "object",
          "properties": {
            ".enabled": {
              "type": "boolean"
            },
            ".left.comment": {
              "type": "string"
            },
            ".right.comment": {
              "type": "string"
            }
          },
          "unevaluatedProperties": false
        }
      }
    },
    "httpDigest": {
      "type": "object",
      "$id": "schema:HttpDigest",
      "$ref": "schema:assertion",
      "properties": {
        "HttpDigest": {
          "type": "object",
          "properties": {
            "maxNonceCount": {
              "type": "integer",
              "default": 30
            },
            "nonceTimeout": {
              "type": "integer",
              "default": 1800000
            },
            "realm": {
              "type": "string"
            },
            "_enabled": {
              "type": "boolean",
              "default": true
            },
            "_leftComment": {
              "type": "string"
            },
            "_rightComment": {
              "type": "string"
            }
          },
          "unevaluatedProperties": false
        }
      },
      "unevaluatedProperties": false
    }
  },
  "type": "object",
  "$ref": "schema:HttpDigest"
}
