      "title": "Retrieve Credentials from Context Variable",
      "type": "object",
      "properties": {
        "otherTargetMessageVariable": {
          "type": "string"
        },
        "target": {
          "type": "string",
          "enum": [
            "REQUEST",
            "RESPONSE",
            "OTHER"
          ],
          "default": "REQUEST"
        },
        "variableName": {
          "type": "string"
        },
        "_enabled": {
          "type": "boolean",
          "default": true
        },
        "_leftComment": {
          "type": "string"
        },
        "_rightComment": {
          "type": "string"
        }
      }
    },
    {
      "type": "object",
      "$id": "https://l7tech.com/2025/json-schema/assertions/VariableCredentialSource/Main",
      "title": "Retrieve Credentials from Context Variable",
      "properties": {
        "VariableCredentialSource": {
          "$ref": "https://l7tech.com/2025/json-schema/assertions/VariableCredentialSource"
        }
      }
    }
  ]
}
