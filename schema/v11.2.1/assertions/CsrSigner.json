{
  "$comment": "Schema for CsrSigner assertion. Self-contained with all dependencies.",
  "definitions": {
    "assertion": {
      "$id": "schema:assertion",
      "type": "object",
      "properties": {
        ".properties": {
          "type": "object",
          "properties": {
            ".enabled": {
              "type": "boolean"
            },
            ".left.comment": {
              "type": "string"
            },
            ".right.comment": {
              "type": "string"
            }
          },
          "unevaluatedProperties": false
        }
      }
    },
    "csrSigner": {
      "type": "object",
