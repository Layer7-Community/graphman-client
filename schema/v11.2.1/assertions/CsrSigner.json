            "expiryAgeDays": {
              "type": "string"
            },
            "keyAlias": {
              "type": "string"
            },
            "nonDefaultKeystoreId": {
              "type": "string"
            },
            "outputPrefix": {
              "type": "string"
            },
            "usesDefaultKeyStore": {
              "type": "boolean",
