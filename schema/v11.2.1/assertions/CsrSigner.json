            },
            "usesDynamicPrivateKey": {
              "type": "boolean",
              "default": false
            }
          },
          "unevaluatedProperties": false
        }
      },
      "unevaluatedProperties": false
    }
  },
  "type": "object",
  "$ref": "schema:CsrSigner"
