{
  "$comment": "Schema for SelectElement assertion. Self-contained with all dependencies.",
  "definitions": {
    "assertion": {
      "$id": "schema:assertion",
      "type": "object",
      "properties": {
        ".properties": {
          "type": "object",
          "properties": {
            ".enabled": {
              "type": "boolean"
            },
            ".left.comment": {
              "type": "string"
            },
            ".right.comment": {
              "type": "string"
            }
          },
          "unevaluatedProperties": false
        }
      }
    },
    "xpathExpression": {
      "type": "object",
      "$id": "schema:sub-types/xpathExpression",
      "properties": {
        "expression": {
          "type": "string"
        },
        "namespaces": {
          "type": "object"
        },
        "xpathVersion": {
          "type": "string",
          "enum": [
            "UNSPECIFIED",
            "XPATH_1_0",
            "XPATH_2_0"
          ],
          "default": "UNSPECIFIED"
        }
      },
      "unevaluatedProperties": false
    },
    "selectElement": {
      "type": "object",
      "$id": "schema:SelectElement",
      "$ref": "schema:assertion",
      "properties": {
        "SelectElement": {
          "type": "object",
          "properties": {
            "elementVariable": {
              "type": "string",
              "default": "element"
            },
            "otherTargetMessageVariable": {
              "type": "string"
            },
            "target": {
              "type": "string",
              "enum": [
                "REQUEST",
                "RESPONSE",
                "OTHER"
              ],
              "default": "REQUEST"
            },
            "xpathExpression": {
              "$ref": "schema:sub-types/xpathExpression"
            },
            "_enabled": {
              "type": "boolean",
              "default": true
            },
            "_leftComment": {
              "type": "string"
            },
            "_rightComment": {
              "type": "string"
            }
          },
          "unevaluatedProperties": false
        }
      },
      "unevaluatedProperties": false
    }
  },
  "type": "object",
  "$ref": "schema:SelectElement"
}
