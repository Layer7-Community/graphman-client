{
  "$comment": "Schema for Swagger assertion. Self-contained with all dependencies.",
  "definitions": {
    "assertion": {
      "$id": "schema:assertion",
      "type": "object",
      "properties": {
        ".properties": {
          "type": "object",
          "properties": {
            ".enabled": {
              "type": "boolean"
            },
            ".left.comment": {
              "type": "string"
            },
            ".right.comment": {
              "type": "string"
            }
          },
          "unevaluatedProperties": false
        }
      }
    },
    "swagger": {
      "type": "object",
      "$id": "schema:Swagger",
      "$ref": "schema:assertion",
      "properties": {
        "Swagger": {
          "type": "object",
          "properties": {
            "prefix": {
              "type": "string"
            },
            "requireSecurityCredentials": {
              "type": "boolean",
              "default": true
            },
            "serviceBase": {
              "type": "string"
            },
            "swaggerDoc": {
              "type": "string"
            },
            "validateMethod": {
              "type": "boolean",
              "default": true
            },
            "validatePath": {
              "type": "boolean",
              "default": true
            },
            "validateScheme": {
              "type": "boolean",
              "default": true
            }
          },
          "unevaluatedProperties": false
        }
      },
      "unevaluatedProperties": false
    }
  },
  "type": "object",
  "$ref": "schema:Swagger"
}
