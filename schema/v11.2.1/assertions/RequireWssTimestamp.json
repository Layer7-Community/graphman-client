{
  "$comment": "Schema for RequireWssTimestamp assertion. Self-contained with all dependencies.",
  "definitions": {
    "assertion": {
      "$id": "schema:assertion",
      "type": "object",
      "properties": {
        ".properties": {
          "type": "object",
          "properties": {
            ".enabled": {
              "type": "boolean"
            },
            ".left.comment": {
              "type": "string"
            },
            ".right.comment": {
              "type": "string"
            }
          },
          "unevaluatedProperties": false
        }
      }
    },
    "identityTarget": {
      "type": "object",
      "$id": "schema:sub-types/identityTarget",
      "properties": {
        "identityId": {
          "type": "string"
        },
        "identityInfo": {
          "type": "string"
        },
        "identityProviderOid": {
          "$ref": "schema:sub-types/goid"
        },
        "targetIdentityType": {
          "type": "string",
          "enum": [
            "USER",
            "GROUP",
            "PROVIDER",
            "TAG"
          ]
        }
      },
      "unevaluatedProperties": false
    },
    "xmlSecurityRecipientContext": {
      "type": "object",
      "$id": "schema:sub-types/xmlSecurityRecipientContext",
      "properties": {
        "actor": {
          "type": "string"
        },
        "base64edX509Certificate": {
          "type": "string"
        }
      },
      "unevaluatedProperties": false
    },
    "timeUnit": {
      "type": "string",
      "$id": "schema:sub-types/timeUnit"
    },
    "goid": {
      "type": "string",
      "$id": "schema:sub-types/goid"
    },
    "requireWssTimestamp": {
      "type": "object",
      "$id": "schema:RequireWssTimestamp",
      "$ref": "schema:assertion",
      "properties": {
        "RequireWssTimestamp": {
          "type": "object",
          "properties": {
            "identityTarget": {
              "$ref": "schema:sub-types/identityTarget"
            },
            "maxExpiryMilliseconds": {
              "type": "number"
            },
            "otherTargetMessageVariable": {
              "type": "string"
            },
            "recipientContext": {
              "$ref": "schema:sub-types/xmlSecurityRecipientContext"
            },
            "signatureRequired": {
              "type": "boolean",
              "default": true
            },
            "target": {
              "type": "string",
              "enum": [
                "REQUEST",
                "RESPONSE",
                "OTHER"
              ],
              "default": "REQUEST"
            },
            "timeUnit": {
              "$ref": "schema:sub-types/timeUnit",
              "default": "m"
            }
          },
          "unevaluatedProperties": false
        }
      },
      "unevaluatedProperties": false
    }
  },
  "type": "object",
  "$ref": "schema:RequireWssTimestamp"
}
