{
  "$comment": "Schema for WsTrustCredentialExchange assertion. Self-contained with all dependencies.",
  "definitions": {
    "assertion": {
      "$id": "schema:assertion",
      "type": "object",
      "properties": {
        ".properties": {
          "type": "object",
          "properties": {
            ".enabled": {
              "type": "boolean"
            },
            ".left.comment": {
              "type": "string"
            },
            ".right.comment": {
              "type": "string"
            }
          },
          "unevaluatedProperties": false
        }
      }
    },
    "wsTrustCredentialExchange": {
      "type": "object",
      "$id": "schema:WsTrustCredentialExchange",
      "$ref": "schema:assertion",
      "properties": {
        "WsTrustCredentialExchange": {
          "type": "object",
          "properties": {
            "appliesTo": {
              "type": "string"
            },
            "issuer": {
              "type": "string"
            },
            "requestType": {
              "type": "string",
              "enum": [
                "http://schemas.xmlsoap.org/ws/2005/02/trust/Issue",
                "http://schemas.xmlsoap.org/ws/2005/02/trust/Validate"
              ],
              "default": "http://schemas.xmlsoap.org/ws/2005/02/trust/Issue"
            },
            "tokenServiceUrl": {
              "type": "string"
            },
            "wsTrustNamespace": {
              "type": "string",
              "enum": [
                "<Not Specified>",
                "http://docs.oasis-open.org/ws-sx/ws-trust/200512",
                "http://schemas.xmlsoap.org/ws/2005/02/trust",
                "http://schemas.xmlsoap.org/ws/2004/04/trust"
              ]
            }
          },
          "unevaluatedProperties": false
        }
      },
      "unevaluatedProperties": false
    }
  },
  "type": "object",
  "$ref": "schema:WsTrustCredentialExchange"
}
