{
  "configName": "ValidateCertificate",
  "name": "Validate Certificate",
  "configSchemas": [
    {
      "$id": "https://l7tech.com/2025/json-schema/assertions/ValidateCertificate",
      "title": "Validate Certificate",
      "type": "object",
      "properties": {
        "logOnly": {
          "type": "boolean",
          "default": false
        },
        "sourceVariable": {
          "type": "string"
        },
        "validationType": {
          "type": "string",
          "enum": [
            "CERTIFICATE_ONLY",
            "PATH_VALIDATION",
            "REVOCATION"
          ],
          "default": "CERTIFICATE_ONLY"
        },
        "variablePrefix": {
          "type": "string",
          "default": "certificateValidation"
        },
        "_enabled": {
          "type": "boolean",
          "default": true
        },
        "_leftComment": {
          "type": "string"
        },
        "_rightComment": {
          "type": "string"
        }
      }
    },
    {
      "type": "object",
      "$id": "https://l7tech.com/2025/json-schema/assertions/ValidateCertificate/Main",
      "title": "Validate Certificate",
      "properties": {
        "ValidateCertificate": {
          "$ref": "https://l7tech.com/2025/json-schema/assertions/ValidateCertificate"
        }
      }
    }
  ]
}
