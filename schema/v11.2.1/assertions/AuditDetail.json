{
  "$comment": "Schema for AuditDetail assertion. Self-contained with all dependencies.",
  "definitions": {
    "assertion": {
      "$id": "schema:assertion",
      "type": "object",
      "properties": {
        ".properties": {
          "type": "object",
          "properties": {
            ".enabled": {
              "type": "boolean"
            },
            ".left.comment": {
              "type": "string"
            },
            ".right.comment": {
              "type": "string"
            }
          },
          "unevaluatedProperties": false
        }
      }
    },
    "auditDetail": {
      "type": "object",
      "$id": "schema:AuditDetail",
      "$ref": "schema:assertion",
      "properties": {
        "AuditDetail": {
          "type": "object",
          "properties": {
            "customLoggerSuffix": {
              "type": "string"
            },
            "detail": {
              "type": "string"
            },
            "category": {
              "type": "string",
              "enum": [
                "Audit",
                "Log"
              ],
              "default": "Audit"
            },
            "level": {
              "type": "string",
              "default": "INFO",
              "enum": [
                "WARNING",
                "INFO",
                "FINE",
                "FINER",
                "FINEST"
              ]
            },
            "loggingOnly": {
              "type": "boolean",
              "default": false
            }
          },
          "unevaluatedProperties": false
        }
      },
      "unevaluatedProperties": false
    }
  },
  "type": "object",
  "$ref": "schema:AuditDetail"
}
