{
  "$comment": "Schema for MessageBuffering assertion. Self-contained with all dependencies.",
  "definitions": {
    "assertion": {
      "$id": "schema:assertion",
      "type": "object",
      "properties": {
        ".properties": {
          "type": "object",
          "properties": {
            ".enabled": {
              "type": "boolean"
            },
            ".left.comment": {
              "type": "string"
            },
            ".right.comment": {
              "type": "string"
            }
          },
          "unevaluatedProperties": false
        }
      }
    },
    "messageBuffering": {
      "type": "object",
      "$id": "schema:MessageBuffering",
      "$ref": "schema:assertion",
      "properties": {
        "MessageBuffering": {
          "type": "object",
          "properties": {
            "alwaysBuffer": {
              "type": "boolean",
              "default": false,
              "enum": [
                true,
                false
              ]
            },
            "neverBuffer": {
              "type": "boolean",
              "default": true
            },
            "otherTargetMessageVariable": {
              "type": "string"
            },
            "target": {
              "type": "string",
              "enum": [
                "REQUEST",
                "RESPONSE",
                "OTHER"
              ],
              "default": "REQUEST"
            }
          },
          "unevaluatedProperties": false
        }
      },
      "unevaluatedProperties": false
    }
  },
  "type": "object",
  "$ref": "schema:MessageBuffering"
}
