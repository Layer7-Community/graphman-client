{
  "$comment": "Schema for SFTPResponse assertion. Self-contained with all dependencies.",
  "definitions": {
    "assertion": {
      "$id": "schema:assertion",
      "type": "object",
      "properties": {
        ".properties": {
          "type": "object",
          "properties": {
            ".enabled": {
              "type": "boolean"
            },
            ".left.comment": {
              "type": "string"
            },
            ".right.comment": {
              "type": "string"
            }
          },
          "unevaluatedProperties": false
        }
      }
    },
    "xmlSecurityRecipientContext": {
      "type": "object",
      "$id": "schema:sub-types/xmlSecurityRecipientContext",
      "properties": {
        "actor": {
          "type": "string"
        },
        "base64edX509Certificate": {
          "type": "string"
        }
      },
      "unevaluatedProperties": false
    },
    "sFTPResponse": {
      "type": "object",
      "$id": "schema:SFTPResponse",
      "$ref": "schema:assertion",
      "properties": {
        "SFTPResponse": {
          "type": "object",
          "properties": {
            "currentSecurityHeaderHandling": {
              "type": "integer",
              "default": 0
            },
            "earlyResponse": {
              "type": "boolean",
              "default": false
            },
            "recipientContext": {
              "$ref": "schema:sub-types/xmlSecurityRecipientContext"
            },
            "responseStatus": {
              "type": "string",
              "default": "0"
            },
            "xmlSecurityActorToPromote": {
              "type": "string"
            },
            "_enabled": {
              "type": "boolean",
              "default": true
            },
            "_leftComment": {
              "type": "string"
            },
            "_rightComment": {
              "type": "string"
            }
          },
          "unevaluatedProperties": false
        }
      },
      "unevaluatedProperties": false
    }
  },
  "type": "object",
  "$ref": "schema:SFTPResponse"
}
