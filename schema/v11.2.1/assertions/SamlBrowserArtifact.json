        "_leftComment": {
          "type": "string"
        },
        "_rightComment": {
          "type": "string"
        }
      }
    },
    {
      "type": "object",
      "$id": "https://l7tech.com/2025/json-schema/assertions/sub-types/authenticationProperties",
      "properties": {
