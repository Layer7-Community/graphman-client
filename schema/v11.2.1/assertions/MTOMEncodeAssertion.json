{
  "$comment": "Schema for MTOMEncodeAssertion assertion. Self-contained with all dependencies.",
  "definitions": {
    "assertion": {
      "$id": "schema:assertion",
      "type": "object",
      "properties": {
        ".properties": {
          "type": "object",
          "properties": {
            ".enabled": {
              "type": "boolean"
            },
            ".left.comment": {
              "type": "string"
            },
            ".right.comment": {
              "type": "string"
            }
          },
          "unevaluatedProperties": false
        }
      }
    },
    "xpathExpression": {
      "type": "object",
      "$id": "schema:sub-types/xpathExpression",
      "properties": {
        "expression": {
          "type": "string"
        },
        "namespaces": {
          "type": "object"
        },
        "xpathVersion": {
          "type": "string",
          "enum": [
            "UNSPECIFIED",
            "XPATH_1_0",
            "XPATH_2_0"
          ],
          "default": "UNSPECIFIED"
        }
      },
      "unevaluatedProperties": false
    },
    "mTOMEncodeAssertion": {
      "type": "object",
      "$id": "schema:MTOMEncodeAssertion",
      "$ref": "schema:assertion",
      "properties": {
        "MTOMEncodeAssertion": {
          "type": "object",
          "properties": {
            "alwaysEncode": {
              "type": "boolean",
              "default": false
            },
            "optimizationThreshold": {
              "type": "integer",
              "default": 0
            },
            "xpathExpressions": {
              "type": "array",
              "items": {
                "$ref": "schema:sub-types/xpathExpression"
              }
            }
          },
          "unevaluatedProperties": false
        }
      },
      "unevaluatedProperties": false
    }
  },
  "type": "object",
  "$ref": "schema:MTOMEncodeAssertion"
}
