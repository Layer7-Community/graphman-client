// Jenkins pipeline for running graphman-client Jest tests.

@Library('apim-jenkins-lib@master') _

pipeline {
    agent { label 'centos9 && dockerhost-03' }
    environment {
        GRAPHMAN_HOME = "${env.WORKSPACE}"
        GRAPHMAN_ENTRYPOINT = "${env.WORKSPACE}/graphman.sh"
        ARTIFACTORY_CREDS = credentials('ARTIFACTORY_USERNAME_TOKEN')
    }
    options {
        timeout(time: 30, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '20'))
    }
    parameters {
        string(name: 'VAR_node_version', defaultValue: '16', description: 'Node.js major version (e.g. 16, 18, 20)')
        booleanParam(name: 'RUN_COVERAGE', defaultValue: true, description: 'Run tests with coverage and publish report')

        // Default gateway
        string(name: 'VAR_default_gateway_address', defaultValue: 'https://localhost:8443/graphman', description: 'Default gateway address. Leave empty to skip default config update.')
        string(name: 'VAR_default_gateway_username', defaultValue: 'admin', description: 'Default gateway username')
        password(name: 'VAR_default_gateway_password', defaultValue: '7layer', description: 'Default gateway password')
        booleanParam(name: 'VAR_default_gateway_reject_unauthorized', defaultValue: false, description: 'Default gateway TLS rejectUnauthorized')
        booleanParam(name: 'VAR_default_gateway_allow_mutations', defaultValue: true, description: 'Default gateway allowMutations')
        password(name: 'VAR_default_gateway_passphrase', defaultValue: '7layer', description: 'Optional: Default gateway passphrase (e.g. for admin key)')

        // Source gateway
        string(name: 'VAR_source_gateway_address', defaultValue: 'https://localhost:8443/graphman', description: 'Source gateway address. Leave empty to skip source config update.')
        string(name: 'VAR_source_gateway_username', defaultValue: 'admin', description: 'Source gateway username')
        password(name: 'VAR_source_gateway_password', defaultValue: '7layer', description: 'Source gateway password')
        booleanParam(name: 'VAR_source_gateway_reject_unauthorized', defaultValue: false, description: 'Source gateway TLS rejectUnauthorized')
        booleanParam(name: 'VAR_source_gateway_allow_mutations', defaultValue: true, description: 'Source gateway allowMutations')
        password(name: 'VAR_source_gateway_passphrase', defaultValue: '7layer', description: 'Optional: Source gateway passphrase (e.g. for admin key)')

        // Target gateway
        string(name: 'VAR_target_gateway_address', defaultValue: 'https://localhost:8443/graphman', description: 'Target gateway address. Leave empty to skip target config update.')
        string(name: 'VAR_target_gateway_username', defaultValue: 'admin', description: 'Target gateway username')
        password(name: 'VAR_target_gateway_password', defaultValue: '7layer', description: 'Target gateway password')
        booleanParam(name: 'VAR_target_gateway_reject_unauthorized', defaultValue: false, description: 'Target gateway TLS rejectUnauthorized')
        booleanParam(name: 'VAR_target_gateway_allow_mutations', defaultValue: true, description: 'Target gateway allowMutations')
        password(name: 'VAR_target_gateway_passphrase', defaultValue: '7layer', description: 'Optional: Target gateway passphrase (e.g. for admin key)')

        // http Proxy Server
        string(name: 'VAR_http_agent_type', defaultValue: 'httpproxy', description: 'default http proxy type')
        string(name: 'VAR_http_proxy_address', defaultValue: 'http://localhost:8080', description: 'default http proxy server address')
        string(name: 'VAR_http_proxy_username', defaultValue: 'root', description: 'http proxy username')
        password(name: 'VAR_http_password', defaultValue: '7layer', description: 'http proxy password')

        // socks Proxy Server
        string(name: 'VAR_socks_agent_type', defaultValue: 'socksproxy', description: 'default socks proxy type')
        string(name: 'VAR_socks_proxy_address', defaultValue: 'socks5://localhost:8080', description: 'default socks proxy server address')
        string(name: 'VAR_socks_proxy_username', defaultValue: 'root', description: 'socks proxy username')
        password(name: 'VAR_socks_password', defaultValue: '7layer', description: 'socks proxy password')
    }
    stages {
        stage('Checkout') {
            steps {
                checkout scm
                echo "Checked out graphman-client at ${env.WORKSPACE}"
            }
        }

        stage('Install Dependencies') {
            steps {
                  withCredentials([
                                usernamePassword(credentialsId: 'ARTIFACTORY_USERNAME_TOKEN', passwordVariable: 'APIKEY', usernameVariable: 'USERNAME'),
                            ])
                  {
                            echo 'Installing dependencies (jest, jest-junit, jest-html-reporters, etc.) ...'
                            configFileProvider([
                                configFile(
                                    fileId: '5e52060e-11e4-4c02-b2b1-4b4463e681d6',   // ID of the npm config in Managed Files
                                    targetLocation: '.npmrc'              // optional: copy to workspace as .npmrc
                                )
                            ]) {
                                    sh 'sed -i "s/:_authToken=/:_authToken=${APIKEY}/" .npmrc'
                                    sh 'npm install --no-audit --no-fund'
                           }
                  }
             }
        }

        stage('Update graphman.configuration') {
            when { expression {
                (params.VAR_default_gateway_address?.trim() != '') || (params.VAR_source_gateway_address?.trim() != '') || (params.VAR_target_gateway_address?.trim() != '')
            } }
            steps {
                script {
                    sh 'mkdir -p build'
                    writeFile file: 'build/update-gateway-config.js', text: '''const fs=require("fs");
                    const cfgFile=(process.env.GRAPHMAN_HOME||".")+"/graphman.configuration";
                    let cfg={};
                    if(fs.existsSync(cfgFile))cfg=JSON.parse(fs.readFileSync(cfgFile,"utf8"));
                    if(!cfg.credentials)cfg.credentials={};
                    if(!cfg.gateways)cfg.gateways={};
                    if(!cfg.proxies)cfg.proxies={};

                    // HTTP Proxy
                    if(process.env.HTTP_PROXY_ADDRESS && process.env.HTTP_PROXY_ADDRESS.trim()!==""){
                        cfg.credentials.proxyCredentials={};
                        cfg.credentials.proxyCredentials.username=process.env.HTTP_PROXY_USER||"";
                        cfg.credentials.proxyCredentials.password=process.env.HTTP_PROXY_PASS||"";

                        cfg.proxies.httpproxy={
                            agentType: process.env.HTTP_AGENT_TYPE || "http",
                            address: process.env.HTTP_PROXY_ADDRESS.trim(),
                            credential: "proxyCredentials",
                            options: {
                                timeout: 30000,
                                keepAlive: true,
                                maxSockets: 10,
                                rejectUnauthorized: false
                            }
                        };
                    }

                    // SOCKS Proxy
                    if(process.env.SOCKS_PROXY_ADDRESS && process.env.SOCKS_PROXY_ADDRESS.trim()!==""){
                        cfg.proxies.socksproxy={
                            agentType: process.env.SOCKS_AGENT_TYPE || "socks",
                            address: process.env.SOCKS_PROXY_ADDRESS.trim(),
                            credential: null,
                            options: {
                                timeout: 30000,
                                keepAlive: true,
                                maxSockets: 10,
                                rejectUnauthorized: false
                            }
                        };
                    }

                    // Default gateway
                    if(process.env.DEFAULT_GW_ADDRESS&&process.env.DEFAULT_GW_ADDRESS.trim()!==""){
                      if(!cfg.credentials.default)cfg.credentials.default={};
                      cfg.credentials.default.username=process.env.DEFAULT_GW_USER||"";
                      cfg.credentials.default.password=process.env.DEFAULT_GW_PASS||"";
                      if(!cfg.gateways.default)cfg.gateways.default={};
                      cfg.gateways.default.address=process.env.DEFAULT_GW_ADDRESS.trim();
                      cfg.gateways.default.credential="default";
                      cfg.gateways.default.rejectUnauthorized=process.env.DEFAULT_GW_REJECT_UNAUTHORIZED==="true";
                      cfg.gateways.default.allowMutations=process.env.DEFAULT_GW_ALLOW_MUTATIONS==="true";
                      if(process.env.DEFAULT_GW_PASSPHRASE)cfg.gateways.default.passphrase=process.env.DEFAULT_GW_PASSPHRASE;
                    }

                    // Source gateway
                    if(process.env.SOURCE_GW_ADDRESS&&process.env.SOURCE_GW_ADDRESS.trim()!==""){
                      if(!cfg.credentials.source)cfg.credentials.source={};
                      cfg.credentials.source.username=process.env.SOURCE_GW_USER||"";
                      cfg.credentials.source.password=process.env.SOURCE_GW_PASS||"";
                      if(!cfg.gateways["source-gateway"])cfg.gateways["source-gateway"]={};
                      cfg.gateways["source-gateway"].address=process.env.SOURCE_GW_ADDRESS.trim();
                      cfg.gateways["source-gateway"].credential="source";
                      cfg.gateways["source-gateway"].rejectUnauthorized=process.env.SOURCE_GW_REJECT_UNAUTHORIZED==="true";
                      cfg.gateways["source-gateway"].allowMutations=process.env.SOURCE_GW_ALLOW_MUTATIONS==="true";
                      cfg.gateways["source-gateway"].proxy="httpproxy";
                      if(process.env.SOURCE_GW_PASSPHRASE)cfg.gateways["source-gateway"].passphrase=process.env.SOURCE_GW_PASSPHRASE;
                    }

                    // Target gateway
                    if(process.env.TARGET_GW_ADDRESS&&process.env.TARGET_GW_ADDRESS.trim()!==""){
                      if(!cfg.credentials.target)cfg.credentials.target={};
                      cfg.credentials.target.username=process.env.TARGET_GW_USER||"";
                      cfg.credentials.target.password=process.env.TARGET_GW_PASS||"";
                      if(!cfg.gateways["target-gateway"])cfg.gateways["target-gateway"]={};
                      cfg.gateways["target-gateway"].address=process.env.TARGET_GW_ADDRESS.trim();
                      cfg.gateways["target-gateway"].credential="target";
                      cfg.gateways["target-gateway"].rejectUnauthorized=process.env.TARGET_GW_REJECT_UNAUTHORIZED==="true";
                      cfg.gateways["target-gateway"].allowMutations=process.env.TARGET_GW_ALLOW_MUTATIONS==="true";
                      if(process.env.TARGET_GW_PASSPHRASE)cfg.gateways["target-gateway"].passphrase=process.env.TARGET_GW_PASSPHRASE;
                    }
                    fs.writeFileSync(cfgFile,JSON.stringify(cfg,null,4));
                    '''

                    // Map Gateway Variables
                    env.DEFAULT_GW_ADDRESS = (params.VAR_default_gateway_address ?: '').trim()
                    env.DEFAULT_GW_REJECT_UNAUTHORIZED = String.valueOf(params.VAR_default_gateway_reject_unauthorized)
                    env.DEFAULT_GW_ALLOW_MUTATIONS = String.valueOf(params.VAR_default_gateway_allow_mutations)
                    env.DEFAULT_GW_PASSPHRASE = params.VAR_default_gateway_passphrase ?: ''
                    env.DEFAULT_GW_USER = params.VAR_default_gateway_username ?: 'admin'
                    env.DEFAULT_GW_PASS = params.VAR_default_gateway_password ?: ''

                    env.SOURCE_GW_ADDRESS = (params.VAR_source_gateway_address ?: '').trim()
                    env.SOURCE_GW_REJECT_UNAUTHORIZED = String.valueOf(params.VAR_source_gateway_reject_unauthorized)
                    env.SOURCE_GW_ALLOW_MUTATIONS = String.valueOf(params.VAR_source_gateway_allow_mutations)
                    env.SOURCE_GW_PASSPHRASE = params.VAR_source_gateway_passphrase ?: ''
                    env.SOURCE_GW_USER = params.VAR_source_gateway_username ?: 'admin'
                    env.SOURCE_GW_PASS = params.VAR_source_gateway_password ?: ''

                    env.TARGET_GW_ADDRESS = (params.VAR_target_gateway_address ?: '').trim()
                    env.TARGET_GW_REJECT_UNAUTHORIZED = String.valueOf(params.VAR_target_gateway_reject_unauthorized)
                    env.TARGET_GW_ALLOW_MUTATIONS = String.valueOf(params.VAR_target_gateway_allow_mutations)
                    env.TARGET_GW_PASSPHRASE = params.VAR_target_gateway_passphrase ?: ''
                    env.TARGET_GW_USER = params.VAR_target_gateway_username ?: 'admin'
                    env.TARGET_GW_PASS = params.VAR_target_gateway_password ?: ''

                    // Map Proxy Variables
                    env.HTTP_AGENT_TYPE = params.VAR_http_agent_type ?: 'httpproxy'
                    env.HTTP_PROXY_ADDRESS = (params.VAR_http_proxy_address ?: '').trim()
                    env.HTTP_PROXY_USER = params.VAR_http_proxy_username ?: 'root'
                    env.HTTP_PROXY_PASS = params.VAR_http_password ?: ''

                    env.SOCKS_AGENT_TYPE = params.VAR_socks_agent_type ?: 'socksproxy'
                    env.SOCKS_PROXY_ADDRESS = (params.VAR_socks_proxy_address ?: '').trim()
                    env.SOCKS_PROXY_USER = params.VAR_socks_proxy_username ?: 'root'
                    env.SOCKS_PROXY_PASS = params.VAR_socks_password ?: ''

                    sh 'node build/update-gateway-config.js'
                    sh 'cat graphman.configuration'
                    echo "Updated graphman.configuration with default, source, target gateway and proxy details."
                }
            }
        }

        stage('Test Init') {
            steps {
                echo 'Running tests/init.js for test configuration ...'
                sh 'node tests/init.js'
            }
        }

        stage('Run Jest Tests') {
            steps {
                echo 'Running graphman-client Jest tests (see TESTING.md) ...'
                script {
                    if (params.RUN_COVERAGE) {
                        sh 'npx jest --coverage'
                    } else {
                        sh 'npm test'
                    }
                }
            }
        }
    }

    post {
        always {
            script {
                junit allowEmptyResults: true, testResults: 'test-reports/junit.xml'
                if (params.RUN_COVERAGE) {
                    publishHTML([
                        allowMissing: true,
                        alwaysLinkToLastBuild: true,
                        keepAll: true,
                        reportDir: 'test-reports',
                        reportFiles: 'test-report.html',
                        reportName: 'Jest HTML Report',
                        reportTitles: ''
                    ])
                    publishHTML([
                        allowMissing: true,
                        alwaysLinkToLastBuild: true,
                        keepAll: true,
                        reportDir: 'coverage/lcov-report',
                        reportFiles: 'index.html',
                        reportName: 'Coverage Report',
                        reportTitles: ''
                    ])
                }
            }
        }
        success {
            echo 'All Jest tests passed.'
        }
        failure {
            echo 'Jest test run failed or reported failures.'
        }
    }
}